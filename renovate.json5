{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  ignorePresets: [
    'workarounds:javaLTSVersions',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/\\.java-version$/',
      ],
      matchStrings: [
        '(?<currentValue>.*)\\n',
      ],
      datasourceTemplate: 'java-version',
      depNameTemplate: 'java',
      extractVersionTemplate: '^(?<version>\\d+)',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/gradle/libs\\.versions\\.toml/',
      ],
      matchStrings: [
        '^jdk\\s*=\\s*"(?<currentValue>\\d+)"',
      ],
      datasourceTemplate: 'java-version',
      depNameTemplate: 'java',
      extractVersionTemplate: '^(?<version>\\d+)',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)\\.kempt\\.toml$/',
      ],
      matchStrings: [
        '\\[ktfmt\\][^\\[]*?version\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'maven',
      registryUrlTemplate: 'https://repo1.maven.org/maven2',
      depNameTemplate: 'com.facebook:ktfmt',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)\\.kempt\\.toml$/',
      ],
      matchStrings: [
        '\\[gjf\\][^\\[]*?version\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'maven',
      registryUrlTemplate: 'https://repo1.maven.org/maven2',
      depNameTemplate: 'com.google.googlejavaformat:google-java-format',
    },
  ],
  packageRules: [
    {
      groupName: 'JDK version',
      matchDepNames: [
        'java',
      ],
      matchDatasources: [
        'java-version',
      ],
    },
    {
      groupName: 'AGP',
      matchDepNames: [
        'com.android.application',
        'com.android.library',
        'com.android.lint',
        'com.android.settings',
        'com.android.test',
      ],
    },
    {
      description: 'Keep the Metro Gradle plugin and compiler bootstrap versions in lockstep',
      groupName: 'Metro bootstrap',
      groupSlug: 'metro-bootstrap',
      matchDepNames: [
        'dev.zacsweers.metro',
        'dev.zacsweers.metro:compiler',
      ],
      matchDatasources: [
        'maven',
      ],
      minimumGroupSize: 2,
    },
    {
      description: 'Disable Kotlin updates - manually managed due to compiler plugin compatibility',
      enabled: false,
      matchPackageNames: [
        '/^org\\.jetbrains\\.kotlin/',
      ],
    },
    {
      description: 'Disable Android Gradle Plugin updates - manually managed',
      enabled: false,
      matchPackageNames: [
        'com.android.lint',
        'com.android.library',
        'com.android.application',
      ],
    },
  ],
}
